{
  "name": "simgrid",
  "version": "0.2.0",
  "description": "One grid for all your simulators — run multiple Expo projects on multiple devices, in parallel, without the alt-tab dance.",
  "type": "module",
  "bin": { "simgrid": "./dist/cli.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "repository": { "type": "git", "url": "git+https://github.com/MatthysDev/simgrid.git" },
  "bugs": { "url": "https://github.com/MatthysDev/simgrid/issues" },
  "homepage": "https://github.com/MatthysDev/simgrid#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": ["expo", "react-native", "simulator", "emulator", "metro", "parallel", "dev-client"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "execa": "^9.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
