{
  "name": "simpit",
  "version": "0.1.0",
  "description": "Pit crew for your simulators — run multiple Expo projects on multiple devices, in parallel, without the alt-tab dance.",
  "type": "module",
  "bin": { "simpit": "./dist/cli.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["expo", "react-native", "simulator", "emulator", "metro", "parallel", "dev-client"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "execa": "^9.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
